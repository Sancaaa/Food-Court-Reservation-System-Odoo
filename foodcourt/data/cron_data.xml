<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron: Cancel Pending Payments (Every 5 minutes) -->
        <record id="ir_cron_cancel_pending_payments" model="ir.cron">
            <field name="name">Food Court: Cancel Pending Payments</field>
            <field name="model_id" ref="foodcourt.model_foodcourt_reservation"/>
            <field name="state">code</field>
            <field name="code">model._cron_cancel_pending_payments()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Cron: Cancel Expired Reservations (Every 5 minutes) -->
        <record id="ir_cron_cancel_expired_reservations" model="ir.cron">
            <field name="name">Food Court: Cancel Expired Reservations</field>
            <field name="model_id" ref="foodcourt.model_foodcourt_reservation"/>
            <field name="state">code</field>
            <field name="code">model._cron_cancel_expired_reservations()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Cron: Send 3-Hour Reminder (Every 15 minutes) -->
        <record id="ir_cron_send_reminder_emails" model="ir.cron">
            <field name="name">Food Court: Send 3-Hour Reminders</field>
            <field name="model_id" ref="foodcourt.model_foodcourt_reservation"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_reminder_emails()</field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
