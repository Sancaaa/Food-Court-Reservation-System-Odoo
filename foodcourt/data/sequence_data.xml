<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================ -->
        <!-- Sequences                                                    -->
        <!-- ============================================================ -->

        <record id="seq_foodcourt_tenant" model="ir.sequence">
            <field name="name">Food Court Tenant</field>
            <field name="code">foodcourt.tenant</field>
            <field name="prefix">TEN/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_foodcourt_reservation" model="ir.sequence">
            <field name="name">Food Court Reservation</field>
            <field name="code">foodcourt.reservation</field>
            <field name="prefix">RES/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_foodcourt_order" model="ir.sequence">
            <field name="name">Food Court Order</field>
            <field name="code">foodcourt.order</field>
            <field name="prefix">ORD/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_foodcourt_payment" model="ir.sequence">
            <field name="name">Food Court Payment</field>
            <field name="code">foodcourt.payment</field>
            <field name="prefix">PAY/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
