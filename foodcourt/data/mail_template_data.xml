<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Email Template: Reservation Confirmed -->
        <record id="email_template_reservation_confirmed" model="mail.template">
            <field name="name">Food Court: Reservation Confirmed</field>
            <field name="model_id" ref="foodcourt.model_foodcourt_reservation"/>
            <field name="subject">Reservation Confirmed - {{ object.name }}</field>
            <field name="email_to">{{ object.customer_email }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Hello <t t-out="object.customer_name or 'Guest'"/>,<br/><br/>
                        Your reservation at our Food Court has been confirmed.<br/><br/>
                        <strong>Details:</strong><br/>
                        - Reservation Number: <t t-out="object.name"/><br/>
                        - Date: <t t-out="object.reservation_date"/><br/>
                        - Time: <t t-out="object.date_start.strftime('%H:%M') if object.date_start else ''"/><br/>
                        - Guests: <t t-out="object.guest_count"/><br/><br/>
                        Please arrive on time. Reservations are automatically cancelled if you do not check in within 15 minutes of your arrival time.<br/><br/>
                        Thank you!
                    </p>
                </div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>

        <!-- Email Template: Reservation Reminder -->
        <record id="email_template_reservation_reminder" model="mail.template">
            <field name="name">Food Court: Reservation Reminder (3 Hours)</field>
            <field name="model_id" ref="foodcourt.model_foodcourt_reservation"/>
            <field name="subject">Reminder: Upcoming Reservation - {{ object.name }}</field>
            <field name="email_to">{{ object.customer_email }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Hello <t t-out="object.customer_name or 'Guest'"/>,<br/><br/>
                        This is a friendly reminder for your upcoming reservation at our Food Court in 3 hours.<br/><br/>
                        <strong>Details:</strong><br/>
                        - Reservation Number: <t t-out="object.name"/><br/>
                        - Date: <t t-out="object.reservation_date"/><br/>
                        - Time: <t t-out="object.date_start.strftime('%H:%M') if object.date_start else ''"/><br/>
                        - Guests: <t t-out="object.guest_count"/><br/><br/>
                        See you soon!
                    </p>
                </div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>
