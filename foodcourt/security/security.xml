<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================ -->
        <!-- Module Category                                              -->
        <!-- ============================================================ -->
        <record id="module_category_foodcourt" model="ir.module.category">
            <field name="name">Food Court</field>
            <field name="sequence">100</field>
        </record>

        <!-- ============================================================ -->
        <!-- Security Groups                                              -->
        <!-- ============================================================ -->

        <!-- Receptionist: handles reservations, table assignments -->
        <record id="group_foodcourt_receptionist" model="res.groups">
            <field name="name">Receptionist</field>
            <field name="category_id" ref="module_category_foodcourt"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Cashier: handles orders and payments -->
        <record id="group_foodcourt_cashier" model="res.groups">
            <field name="name">Cashier</field>
            <field name="category_id" ref="module_category_foodcourt"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Tenant Manager: manages own stall menus -->
        <record id="group_foodcourt_tenant" model="res.groups">
            <field name="name">Tenant Manager</field>
            <field name="category_id" ref="module_category_foodcourt"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Food Court Manager: supervises all operations -->
        <record id="group_foodcourt_manager" model="res.groups">
            <field name="name">Food Court Manager</field>
            <field name="category_id" ref="module_category_foodcourt"/>
            <field name="implied_ids" eval="[
                (4, ref('group_foodcourt_receptionist')),
                (4, ref('group_foodcourt_cashier')),
            ]"/>
        </record>

        <!-- Administrator: full access to everything -->
        <record id="group_foodcourt_admin" model="res.groups">
            <field name="name">Administrator</field>
            <field name="category_id" ref="module_category_foodcourt"/>
            <field name="implied_ids" eval="[(4, ref('group_foodcourt_manager'))]"/>
        </record>

        <!-- ============================================================ -->
        <!-- Multi-Company Record Rules                                   -->
        <!-- ============================================================ -->

        <record id="rule_foodcourt_floor_company" model="ir.rule">
            <field name="name">Food Court Floor: Multi-Company</field>
            <field name="model_id" ref="model_foodcourt_floor"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_foodcourt_stall_company" model="ir.rule">
            <field name="name">Food Court Stall: Multi-Company</field>
            <field name="model_id" ref="model_foodcourt_stall"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_foodcourt_tenant_company" model="ir.rule">
            <field name="name">Food Court Tenant: Multi-Company</field>
            <field name="model_id" ref="model_foodcourt_tenant"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_foodcourt_table_company" model="ir.rule">
            <field name="name">Food Court Table: Multi-Company</field>
            <field name="model_id" ref="model_foodcourt_table"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_foodcourt_menu_category_company" model="ir.rule">
            <field name="name">Food Court Menu Category: Multi-Company</field>
            <field name="model_id" ref="model_foodcourt_menu_category"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_foodcourt_menu_item_company" model="ir.rule">
            <field name="name">Food Court Menu Item: Multi-Company</field>
            <field name="model_id" ref="model_foodcourt_menu_item"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_foodcourt_reservation_company" model="ir.rule">
            <field name="name">Food Court Reservation: Multi-Company</field>
            <field name="model_id" ref="model_foodcourt_reservation"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_foodcourt_order_company" model="ir.rule">
            <field name="name">Food Court Order: Multi-Company</field>
            <field name="model_id" ref="model_foodcourt_order"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_foodcourt_order_line_company" model="ir.rule">
            <field name="name">Food Court Order Line: Multi-Company</field>
            <field name="model_id" ref="model_foodcourt_order_line"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_foodcourt_payment_company" model="ir.rule">
            <field name="name">Food Court Payment: Multi-Company</field>
            <field name="model_id" ref="model_foodcourt_payment"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <!-- ============================================================ -->
        <!-- Tenant Manager Record Rules (own data only)                  -->
        <!-- ============================================================ -->

        <!-- Tenant managers can only see their own tenant record -->
        <record id="rule_foodcourt_tenant_own" model="ir.rule">
            <field name="name">Food Court Tenant: Own Tenant Only</field>
            <field name="model_id" ref="model_foodcourt_tenant"/>
            <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_foodcourt_tenant'))]"/>
        </record>

        <!-- Tenant managers can only see stalls linked to their tenant -->
        <record id="rule_foodcourt_stall_tenant" model="ir.rule">
            <field name="name">Food Court Stall: Own Tenant Only</field>
            <field name="model_id" ref="model_foodcourt_stall"/>
            <field name="domain_force">[('tenant_id.partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_foodcourt_tenant'))]"/>
        </record>

        <!-- Tenant managers can only see menu items for their own tenant -->
        <record id="rule_foodcourt_menu_item_tenant" model="ir.rule">
            <field name="name">Food Court Menu Item: Own Tenant Only</field>
            <field name="model_id" ref="model_foodcourt_menu_item"/>
            <field name="domain_force">[('tenant_id.partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_foodcourt_tenant'))]"/>
        </record>

        <!-- Tenant managers can only see orders for their own tenant -->
        <record id="rule_foodcourt_order_tenant" model="ir.rule">
            <field name="name">Food Court Order: Own Tenant Only</field>
            <field name="model_id" ref="model_foodcourt_order"/>
            <field name="domain_force">[('tenant_id.partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_foodcourt_tenant'))]"/>
        </record>

        <!-- Tenant managers can only see order lines for their own tenant -->
        <record id="rule_foodcourt_order_line_tenant" model="ir.rule">
            <field name="name">Food Court Order Line: Own Tenant Only</field>
            <field name="model_id" ref="model_foodcourt_order_line"/>
            <field name="domain_force">[('order_id.tenant_id.partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_foodcourt_tenant'))]"/>
        </record>

    </data>
</odoo>
