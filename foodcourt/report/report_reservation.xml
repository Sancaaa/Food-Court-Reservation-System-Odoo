<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_reservation" model="ir.actions.report">
        <field name="name">Reservation Confirmation</field>
        <field name="model">foodcourt.reservation</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">foodcourt.report_reservation_document</field>
        <field name="report_file">foodcourt.report_reservation_document</field>
        <field name="binding_model_id" ref="model_foodcourt_reservation"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_reservation_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center">Reservation Confirmation</h2>
                        <h3 class="text-center text-muted"><span t-field="o.name"/></h3>
                        
                        <div class="row mt-4 mb-4">
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr><td class="fw-bold">Customer</td><td><span t-field="o.customer_name"/></td></tr>
                                    <tr><td class="fw-bold">Phone</td><td><span t-field="o.customer_phone"/></td></tr>
                                    <tr><td class="fw-bold">Email</td><td><span t-field="o.customer_email"/></td></tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr><td class="fw-bold">Date</td><td><span t-field="o.reservation_date"/></td></tr>
                                    <tr><td class="fw-bold">Time</td><td><span t-field="o.time_start" t-options='{"widget": "float_time"}'/> - <span t-field="o.time_end" t-options='{"widget": "float_time"}'/></td></tr>
                                    <tr><td class="fw-bold">Guests</td><td><span t-field="o.guest_count"/> person(s)</td></tr>
                                    <tr><td class="fw-bold">Status</td><td><span t-field="o.state"/></td></tr>
                                </table>
                            </div>
                        </div>

                        <h4>Reserved Tables</h4>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Table</th>
                                    <th>Floor</th>
                                    <th>Seats</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.table_ids" t-as="table">
                                    <tr>
                                        <td><span t-field="table.name"/></td>
                                        <td><span t-field="table.floor_id"/></td>
                                        <td><span t-field="table.seats"/> seats</td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <t t-if="o.notes">
                            <h4>Special Requests</h4>
                            <p><span t-field="o.notes"/></p>
                        </t>

                        <div class="mt-4 text-center text-muted">
                            <p>Thank you for your reservation. Please arrive on time.</p>
                            <p>For changes or cancellations, please contact us.</p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
