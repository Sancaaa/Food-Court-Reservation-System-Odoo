<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Revenue Report Template -->
    <template id="report_revenue_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Tenant Revenue Report</h2>
                        <div class="row mt-4">
                            <div class="col-6">
                                <h4>Tenant Information</h4>
                                <div>
                                    <strong>Name:</strong>
                                    <span t-field="doc.name"/>
                                </div>
                                <div t-if="doc.partner_id">
                                    <strong>Contact:</strong>
                                    <span t-field="doc.partner_id"/>
                                </div>
                                <div t-if="doc.cuisine_type">
                                    <strong>Cuisine:</strong>
                                    <span t-field="doc.cuisine_type"/>
                                </div>
                            </div>
                            <div class="col-6">
                                <h4>Revenue Summary</h4>
                                <div>
                                    <strong>Total Revenue:</strong>
                                    <span t-field="doc.total_revenue"
                                          t-options="{'widget': 'monetary',
                                                      'display_currency': doc.currency_id}"/>
                                </div>
                                <div>
                                    <strong>Revenue Share (%):</strong>
                                    <span t-field="doc.revenue_share_pct"/>%
                                </div>
                            </div>
                        </div>

                        <div class="row mt-4" t-if="doc.product_ids">
                            <div class="col-12">
                                <h4>Products</h4>
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Product</th>
                                            <th class="text-end">Price</th>
                                            <th>Available in POS</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="doc.product_ids" t-as="product">
                                            <td t-field="product.name"/>
                                            <td class="text-end" t-field="product.list_price"
                                                t-options="{'widget': 'monetary',
                                                            'display_currency': doc.currency_id}"/>
                                            <td t-field="product.available_in_pos"/>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="row mt-4">
                            <div class="col-6">
                                <strong>Contract Period:</strong>
                                <span t-field="doc.contract_start"/> -
                                <span t-field="doc.contract_end"/>
                            </div>
                            <div class="col-6 text-end">
                                <strong>Status:</strong>
                                <span t-field="doc.state"/>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- Revenue Report Action -->
    <record id="action_report_revenue" model="ir.actions.report">
        <field name="name">Tenant Revenue Report</field>
        <field name="model">foodcourt.tenant</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">foodcourt.report_revenue_document</field>
        <field name="report_file">foodcourt.report_revenue_document</field>
        <field name="binding_model_id" ref="model_foodcourt_tenant"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
