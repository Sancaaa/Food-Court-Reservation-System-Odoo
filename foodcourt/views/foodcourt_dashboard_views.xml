<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Reservation Analysis Graph View -->
    <record id="view_foodcourt_reservation_graph" model="ir.ui.view">
        <field name="name">foodcourt.reservation.graph</field>
        <field name="model">foodcourt.reservation</field>
        <field name="arch" type="xml">
            <graph string="Reservation Analysis" type="bar">
                <field name="reservation_date" interval="month"/>
                <field name="guest_count" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Reservation Analysis Pivot View -->
    <record id="view_foodcourt_reservation_pivot" model="ir.ui.view">
        <field name="name">foodcourt.reservation.pivot</field>
        <field name="model">foodcourt.reservation</field>
        <field name="arch" type="xml">
            <pivot string="Reservation Analysis">
                <field name="reservation_date" interval="month" type="row"/>
                <field name="state" type="col"/>
                <field name="guest_count" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Reservation Analysis Search View -->
    <record id="view_foodcourt_reservation_analysis_search" model="ir.ui.view">
        <field name="name">foodcourt.reservation.analysis.search</field>
        <field name="model">foodcourt.reservation</field>
        <field name="arch" type="xml">
            <search string="Reservation Analysis">
                <field name="reservation_date"/>
                <field name="state"/>
                <separator/>
                <filter string="Reservation Date" name="group_reservation_date"
                        context="{'group_by': 'reservation_date:month'}"/>
                <filter string="Status" name="group_state"
                        context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <!-- Reservation Analysis Action -->
    <record id="action_foodcourt_reservation_analysis" model="ir.actions.act_window">
        <field name="name">Reservation Analysis</field>
        <field name="res_model">foodcourt.reservation</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="search_view_id" ref="view_foodcourt_reservation_analysis_search"/>
        <field name="context">{'search_default_group_reservation_date': 1}</field>
    </record>

</odoo>
