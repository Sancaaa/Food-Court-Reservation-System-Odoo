<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--                      ORDER VIEWS                             -->
    <!-- ============================================================ -->

    <!-- Order: Form View -->
    <record id="view_foodcourt_order_form" model="ir.ui.view">
        <field name="name">foodcourt.order.form</field>
        <field name="model">foodcourt.order</field>
        <field name="arch" type="xml">
            <form string="Order">
                <header>
                    <button name="action_confirm" string="Confirm"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_prepare" string="Prepare"
                            type="object" class="btn-primary"
                            invisible="state != 'confirmed'"/>
                    <button name="action_ready" string="Ready"
                            type="object" class="btn-primary"
                            invisible="state != 'preparing'"/>
                    <button name="action_serve" string="Serve"
                            type="object" class="btn-primary"
                            invisible="state != 'ready'"/>
                    <button name="action_done" string="Done"
                            type="object" class="btn-primary"
                            invisible="state != 'served'"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state in ('done', 'cancelled')"
                            confirm="Are you sure you want to cancel this order?"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,preparing,ready,served,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Customer">
                            <field name="customer_name"/>
                            <field name="customer_id"/>
                            <field name="reservation_id"/>
                        </group>
                        <group string="Order Details">
                            <field name="order_date"/>
                            <field name="order_type"/>
                            <field name="table_id"/>
                            <field name="payment_state" widget="badge"
                                   decoration-success="payment_state == 'paid'"
                                   decoration-warning="payment_state == 'partial'"
                                   decoration-danger="payment_state == 'unpaid'"/>
                            </group>
                    </group>
                    <notebook>
                        <page string="Order Lines" name="order_lines">
                            <field name="line_ids" editable="bottom">
                                <list editable="bottom">
                                    <field name="menu_item_id"/>
                                    <field name="tenant_id"/>
                                    <field name="quantity"/>
                                    <field name="unit_price" widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="subtotal" widget="monetary"
                                           options="{'currency_field': 'currency_id'}"
                                           sum="Total"/>
                                    <field name="notes"/>
                                    <field name="state" widget="badge"
                                           decoration-info="state == 'pending'"
                                           decoration-warning="state == 'preparing'"
                                           decoration-success="state in ('ready', 'served')"/>
                                </list>
                            </field>
                        </page>
                        <page string="Payment" name="payment">
                            <field name="payment_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="amount" widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="payment_method"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'confirmed'"
                                           decoration-danger="state == 'refunded'"
                                           decoration-info="state == 'draft'"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="subtotal" widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                                <field name="tax_pct"/>
                                <field name="tax_amount" widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                                <div class="oe_subtotal_footer_separator">
                                    <field name="total_amount" widget="monetary"
                                           options="{'currency_field': 'currency_id'}"
                                           class="oe_subtotal_footer_separator"/>
                                </div>
                                <field name="amount_paid" widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                                <field name="amount_due" widget="monetary"
                                       options="{'currency_field': 'currency_id'}"
                                       class="oe_subtotal_footer_separator"/>
                            </group>
                            <div class="oe_clear"/>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes"
                                   placeholder="Internal notes about the order..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Order: List View -->
    <record id="view_foodcourt_order_list" model="ir.ui.view">
        <field name="name">foodcourt.order.list</field>
        <field name="model">foodcourt.order</field>
        <field name="arch" type="xml">
            <list string="Orders"
                  decoration-muted="state == 'cancelled'"
                  decoration-success="state == 'done'"
                  decoration-info="state in ('confirmed', 'preparing')">
                <field name="name"/>
                <field name="customer_name"/>
                <field name="order_date"/>
                <field name="order_type"/>
                <field name="total_amount" widget="monetary"
                       options="{'currency_field': 'currency_id'}" sum="Total"/>
                <field name="payment_state" widget="badge"
                       decoration-success="payment_state == 'paid'"
                       decoration-warning="payment_state == 'partial'"
                       decoration-danger="payment_state == 'unpaid'"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-info="state in ('confirmed', 'preparing', 'ready')"
                       decoration-warning="state == 'served'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- Order: Kanban View (Kitchen Display) -->
    <record id="view_foodcourt_order_kanban" model="ir.ui.view">
        <field name="name">foodcourt.order.kanban</field>
        <field name="model">foodcourt.order</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column"
                    records_draggable="false">
                <templates>
                    <t t-name="card">
                        <div class="d-flex justify-content-between">
                            <strong>
                                <field name="name"/>
                            </strong>
                            <field name="payment_state" widget="label_selection"
                                   options="{'classes': {
                                       'unpaid': 'danger',
                                       'partial': 'warning',
                                       'paid': 'success'
                                   }}"/>
                        </div>
                        <div>
                            <i class="fa fa-user me-1"/><field name="customer_name"/>
                        </div>
                        <div>
                            <field name="order_type"/>
                            <span t-if="record.table_id.value">
                                - <field name="table_id"/>
                            </span>
                        </div>
                        <div class="mt-1">
                            <strong>
                                <field name="total_amount" widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                            </strong>
                            </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Order: Search View -->
    <record id="view_foodcourt_order_search" model="ir.ui.view">
        <field name="name">foodcourt.order.search</field>
        <field name="model">foodcourt.order</field>
        <field name="arch" type="xml">
            <search string="Search Orders">
                <field name="name"/>
                <field name="customer_name"/>
                <field name="reservation_id"/>
                <separator/>
                <filter string="Draft" name="draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="confirmed"
                        domain="[('state', '=', 'confirmed')]"/>
                <filter string="Preparing" name="preparing"
                        domain="[('state', '=', 'preparing')]"/>
                <filter string="Ready" name="ready"
                        domain="[('state', '=', 'ready')]"/>
                <filter string="Served" name="served"
                        domain="[('state', '=', 'served')]"/>
                <filter string="Done" name="done"
                        domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter string="Unpaid" name="unpaid"
                        domain="[('payment_state', '=', 'unpaid')]"/>
                <filter string="Partially Paid" name="partial"
                        domain="[('payment_state', '=', 'partial')]"/>
                <filter string="Paid" name="paid"
                        domain="[('payment_state', '=', 'paid')]"/>
                <separator/>
                <filter string="Dine In" name="dine_in"
                        domain="[('order_type', '=', 'dine_in')]"/>
                <filter string="Takeaway" name="takeaway"
                        domain="[('order_type', '=', 'takeaway')]"/>
                <separator/>
                <filter string="Today" name="today"
                        domain="[('order_date', '&gt;=', (context_today()).strftime('%Y-%m-%d 00:00:00')),
                                 ('order_date', '&lt;=', (context_today()).strftime('%Y-%m-%d 23:59:59'))]"/>
            </search>
        </field>
    </record>

    <!-- Order: Window Action -->
    <record id="action_foodcourt_order" model="ir.actions.act_window">
        <field name="name">Orders</field>
        <field name="res_model">foodcourt.order</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_foodcourt_order_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first order
            </p>
            <p>
                Manage food court orders from creation to completion.
            </p>
        </field>
    </record>

</odoo>

