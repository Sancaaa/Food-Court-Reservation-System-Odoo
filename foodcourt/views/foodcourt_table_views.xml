<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--                      TABLE VIEWS                             -->
    <!-- ============================================================ -->

    <!-- Form View -->
    <record id="view_foodcourt_table_form" model="ir.ui.view">
        <field name="name">foodcourt.table.form</field>
        <field name="model">foodcourt.table</field>
        <field name="arch" type="xml">
            <form string="Table">
                <header>
                    <button name="action_set_available" string="Set Available"
                            type="object" class="oe_highlight"
                            invisible="state == 'available'"/>
                    <button name="action_set_occupied" string="Set Occupied"
                            type="object"
                            invisible="state in ('occupied', 'cleaning')"/>
                    <button name="action_set_cleaning" string="Set Cleaning"
                            type="object"
                            invisible="state in ('available', 'cleaning')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="available,reserved,occupied,cleaning"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"
                                   placeholder="e.g. T-01"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="floor_id"/>
                            <field name="capacity"/>
                        </group>
                        <group>
                            <field name="state"/>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"
                               placeholder="Internal notes about this table..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_foodcourt_table_list" model="ir.ui.view">
        <field name="name">foodcourt.table.list</field>
        <field name="model">foodcourt.table</field>
        <field name="arch" type="xml">
            <list string="Tables">
                <field name="name"/>
                <field name="floor_id"/>
                <field name="capacity"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'available'"
                       decoration-warning="state == 'reserved'"
                       decoration-danger="state == 'occupied'"
                       decoration-info="state == 'cleaning'"/>
                <field name="company_id" optional="hide"
                       groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_foodcourt_table_kanban" model="ir.ui.view">
        <field name="name">foodcourt.table.kanban</field>
        <field name="model">foodcourt.table</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <templates>
                    <t t-name="card">
                        <div class="d-flex justify-content-between mb-2">
                            <h3 class="mb-0">
                                <field name="name"/>
                            </h3>
                            <field name="state" widget="badge"
                                   decoration-success="state == 'available'"
                                   decoration-warning="state == 'reserved'"
                                   decoration-danger="state == 'occupied'"
                                   decoration-info="state == 'cleaning'"/>
                        </div>
                        <div class="text-muted small">
                            <i class="fa fa-building me-1"/>
                            <field name="floor_id"/>
                        </div>
                        <div class="mt-1">
                            <i class="fa fa-users me-1"/>
                            <field name="capacity"/> persons
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_foodcourt_table_search" model="ir.ui.view">
        <field name="name">foodcourt.table.search</field>
        <field name="model">foodcourt.table</field>
        <field name="arch" type="xml">
            <search string="Search Tables">
                <field name="name"/>
                <field name="floor_id"/>
                <separator/>
                <filter name="filter_available" string="Available"
                        domain="[('state', '=', 'available')]"/>
                <filter name="filter_reserved" string="Reserved"
                        domain="[('state', '=', 'reserved')]"/>
                <filter name="filter_occupied" string="Occupied"
                        domain="[('state', '=', 'occupied')]"/>
                <filter name="filter_cleaning" string="Cleaning"
                        domain="[('state', '=', 'cleaning')]"/>
                <separator/>
                <filter name="filter_active" string="Active"
                        domain="[('active', '=', True)]"/>
                <filter name="filter_archived" string="Archived"
                        domain="[('active', '=', False)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_floor" string="Floor/Area"
                            context="{'group_by': 'floor_id'}"/>
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_foodcourt_table" model="ir.actions.act_window">
        <field name="name">Tables</field>
        <field name="res_model">foodcourt.table</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_foodcourt_table_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first table
            </p>
            <p>
                Add tables to floors and track their availability
                in real time.
            </p>
        </field>
    </record>

</odoo>
