<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--                  MENU CATEGORY VIEWS                         -->
    <!-- ============================================================ -->

    <!-- Menu Category: Form View -->
    <record id="view_foodcourt_menu_category_form" model="ir.ui.view">
        <field name="name">foodcourt.menu.category.form</field>
        <field name="model">foodcourt.menu.category</field>
        <field name="arch" type="xml">
            <form string="Menu Category">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <field name="image" widget="image" class="oe_avatar"
                           options="{'preview_image': 'image'}"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Category Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="parent_id"/>
                        </group>
                        <group>
                            <field name="item_count"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Menu Items" name="menu_items">
                            <field name="menu_item_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="tenant_id"/>
                                    <field name="price"/>
                                    <field name="is_available" widget="boolean"/>
                                    <field name="preparation_time"/>
                                </list>
                            </field>
                        </page>
                        <page string="Sub Categories" name="sub_categories">
                            <field name="child_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="item_count"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Menu Category: List View -->
    <record id="view_foodcourt_menu_category_list" model="ir.ui.view">
        <field name="name">foodcourt.menu.category.list</field>
        <field name="model">foodcourt.menu.category</field>
        <field name="arch" type="xml">
            <list string="Menu Categories">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="parent_id"/>
                <field name="item_count"/>
            </list>
        </field>
    </record>

    <!-- Menu Category: Search View -->
    <record id="view_foodcourt_menu_category_search" model="ir.ui.view">
        <field name="name">foodcourt.menu.category.search</field>
        <field name="model">foodcourt.menu.category</field>
        <field name="arch" type="xml">
            <search string="Search Categories">
                <field name="name"/>
                <field name="parent_id"/>
                <separator/>
                <filter string="Archived" name="inactive"
                        domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Parent Category" name="group_parent"
                            context="{'group_by': 'parent_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Menu Category: Window Action -->
    <record id="action_foodcourt_menu_category" model="ir.actions.act_window">
        <field name="name">Menu Categories</field>
        <field name="res_model">foodcourt.menu.category</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_foodcourt_menu_category_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first menu category
            </p>
            <p>
                Organize your menu items into categories and subcategories.
            </p>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                    MENU ITEM VIEWS                           -->
    <!-- ============================================================ -->

    <!-- Menu Item: Form View -->
    <record id="view_foodcourt_menu_item_form" model="ir.ui.view">
        <field name="name">foodcourt.menu.item.form</field>
        <field name="model">foodcourt.menu.item</field>
        <field name="arch" type="xml">
            <form string="Menu Item">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <field name="image" widget="image" class="oe_avatar"
                           options="{'preview_image': 'image'}"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Item Name"/>
                        </h1>
                        <field name="code" placeholder="Item Code"/>
                    </div>
                    <group>
                        <group>
                            <field name="tenant_id"/>
                            <field name="category_id"/>
                            <field name="price" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                            </group>
                        <group>
                            <field name="preparation_time"/>
                            <field name="active" invisible="1"/>
                            </group>
                    </group>
                    <!-- Boolean badges row -->
                    <div class="d-flex gap-2 mb-3">
                        <field name="is_available" widget="boolean_toggle"/>
                        <label for="is_available"/>
                        <field name="is_halal" widget="boolean_toggle"/>
                        <label for="is_halal"/>
                        <field name="is_vegetarian" widget="boolean_toggle"/>
                        <label for="is_vegetarian"/>
                        <field name="is_spicy" widget="boolean_toggle"/>
                        <label for="is_spicy"/>
                    </div>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Describe the menu item..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Menu Item: List View -->
    <record id="view_foodcourt_menu_item_list" model="ir.ui.view">
        <field name="name">foodcourt.menu.item.list</field>
        <field name="model">foodcourt.menu.item</field>
        <field name="arch" type="xml">
            <list string="Menu Items" multi_edit="1">
                <field name="name"/>
                <field name="tenant_id"/>
                <field name="category_id"/>
                <field name="price" widget="monetary"
                       options="{'currency_field': 'currency_id'}"/>
                <field name="is_available" widget="boolean"/>
                <field name="is_halal" widget="boolean"/>
                <field name="preparation_time"/>
            </list>
        </field>
    </record>

    <!-- Menu Item: Kanban View -->
    <record id="view_foodcourt_menu_item_kanban" model="ir.ui.view">
        <field name="name">foodcourt.menu.item.kanban</field>
        <field name="model">foodcourt.menu.item</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <templates>
                    <t t-name="card">
                        <aside>
                            <field name="image" widget="image" options="{'preview_image': 'image'}"/>
                        </aside>
                        <main>
                            <strong>
                                <field name="name"/>
                            </strong>
                            <field name="tenant_id"/>
                            <field name="price" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                            <div class="d-flex gap-1 mt-1">
                                <span t-if="record.is_available.raw_value"
                                      class="badge rounded-pill text-bg-success">
                                    Available
                                </span>
                                <span t-else=""
                                      class="badge rounded-pill text-bg-danger">
                                    Unavailable
                                </span>
                                <span t-if="record.is_halal.raw_value"
                                      class="badge rounded-pill text-bg-info"
                                      title="Halal">
                                    <i class="fa fa-check-circle"/> Halal
                                </span>
                                <span t-if="record.is_vegetarian.raw_value"
                                      class="badge rounded-pill text-bg-success"
                                      title="Vegetarian">
                                    <i class="fa fa-leaf"/> Veg
                                </span>
                                <span t-if="record.is_spicy.raw_value"
                                      class="badge rounded-pill text-bg-warning"
                                      title="Spicy">
                                    <i class="fa fa-fire"/> Spicy
                                </span>
                            </div>
                        </main>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Menu Item: Search View -->
    <record id="view_foodcourt_menu_item_search" model="ir.ui.view">
        <field name="name">foodcourt.menu.item.search</field>
        <field name="model">foodcourt.menu.item</field>
        <field name="arch" type="xml">
            <search string="Search Menu Items">
                <field name="name"/>
                <field name="tenant_id"/>
                <field name="category_id"/>
                <separator/>
                <filter string="Available" name="available"
                        domain="[('is_available', '=', True)]"/>
                <filter string="Halal" name="halal"
                        domain="[('is_halal', '=', True)]"/>
                <filter string="Vegetarian" name="vegetarian"
                        domain="[('is_vegetarian', '=', True)]"/>
                <separator/>
                <filter string="Archived" name="inactive"
                        domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Tenant" name="group_tenant"
                            context="{'group_by': 'tenant_id'}"/>
                    <filter string="Category" name="group_category"
                            context="{'group_by': 'category_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Menu Item: Window Action -->
    <record id="action_foodcourt_menu_item" model="ir.actions.act_window">
        <field name="name">Menu Items</field>
        <field name="res_model">foodcourt.menu.item</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_foodcourt_menu_item_search"/>
        <field name="context">{'search_default_available': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first menu item
            </p>
            <p>
                Add food and beverage items offered by your tenants.
            </p>
        </field>
    </record>

</odoo>

