<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--                     PAYMENT VIEWS                            -->
    <!-- ============================================================ -->

    <!-- Payment: Form View -->
    <record id="view_foodcourt_payment_form" model="ir.ui.view">
        <field name="name">foodcourt.payment.form</field>
        <field name="model">foodcourt.payment</field>
        <field name="arch" type="xml">
            <form string="Payment">
                <header>
                    <button name="action_confirm" string="Confirm"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_refund" string="Refund"
                            type="object" class="btn-danger"
                            invisible="state != 'confirmed'"
                            confirm="Are you sure you want to refund this payment?"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Payment Details">
                            <field name="order_id"/>
                            <field name="customer_id"/>
                            <field name="amount" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                            <field name="payment_method"/>
                        </group>
                        <group string="Additional Info">
                            <field name="payment_date"/>
                            <field name="reference"/>
                            </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1" colspan="2"
                               placeholder="Payment notes..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Payment: List View -->
    <record id="view_foodcourt_payment_list" model="ir.ui.view">
        <field name="name">foodcourt.payment.list</field>
        <field name="model">foodcourt.payment</field>
        <field name="arch" type="xml">
            <list string="Payments"
                  decoration-success="state == 'confirmed'"
                  decoration-danger="state == 'refunded'"
                  decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="order_id"/>
                <field name="customer_id"/>
                <field name="amount" widget="monetary"
                       options="{'currency_field': 'currency_id'}" sum="Total"/>
                <field name="payment_method"/>
                <field name="payment_date"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'confirmed'"
                       decoration-danger="state == 'refunded'"
                       decoration-info="state == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- Payment: Search View -->
    <record id="view_foodcourt_payment_search" model="ir.ui.view">
        <field name="name">foodcourt.payment.search</field>
        <field name="model">foodcourt.payment</field>
        <field name="arch" type="xml">
            <search string="Search Payments">
                <field name="name"/>
                <field name="order_id"/>
                <field name="customer_id"/>
                <separator/>
                <filter string="Draft" name="draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="confirmed"
                        domain="[('state', '=', 'confirmed')]"/>
                <filter string="Refunded" name="refunded"
                        domain="[('state', '=', 'refunded')]"/>
                <separator/>
                <filter string="Cash" name="cash"
                        domain="[('payment_method', '=', 'cash')]"/>
                <filter string="Debit Card" name="debit_card"
                        domain="[('payment_method', '=', 'debit_card')]"/>
                <filter string="Credit Card" name="credit_card"
                        domain="[('payment_method', '=', 'credit_card')]"/>
                <filter string="E-Wallet" name="ewallet"
                        domain="[('payment_method', '=', 'ewallet')]"/>
                <filter string="Bank Transfer" name="bank_transfer"
                        domain="[('payment_method', '=', 'bank_transfer')]"/>
                <filter string="QRIS" name="qris"
                        domain="[('payment_method', '=', 'qris')]"/>
            </search>
        </field>
    </record>

    <!-- Payment: Window Action -->
    <record id="action_foodcourt_payment" model="ir.actions.act_window">
        <field name="name">Payments</field>
        <field name="res_model">foodcourt.payment</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_foodcourt_payment_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first payment
            </p>
            <p>
                Track all payments received for food court orders.
            </p>
        </field>
    </record>

</odoo>

